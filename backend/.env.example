# ============================================================================
# StrideAlytics Backend — environment variables
# Copy to `.env` and fill in real values. Never commit the `.env` file.
# ============================================================================

# --- App ---
APP_NAME=StrideAlytics
DEBUG=false
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (Supabase / Postgres) ---
# Find in: Supabase dashboard → Project → Settings → Database → Connection string
# Use the "Transaction pooler" URL for serverless, "Direct" for migrations.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
DATABASE_POOL_SIZE=5

# --- Supabase Auth ---
# URL + anon key from: Project Settings → API
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to the browser
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET   # Project Settings → API → JWT Secret

# --- Notifications ---
SENDGRID_API_KEY=SG....            # weekly picks email
SLACK_WEBHOOK=https://hooks.slack.com/services/...   # failure alerts

# --- Internal scheduler (optional, for self-hosted cron) ---
ENABLE_INTERNAL_SCHEDULER=false
