# ============================================================================
# secrets/staging.env.example — STAGING SECRETS (real values git-ignored)
# ============================================================================
# Used by Render (staging service) and Vercel (preview deploys).
# Copy to `secrets/staging.env`, fill in, then run:
#   scripts/load-secrets.ps1 -Env staging
# ============================================================================

APP_NAME=StrideAlytics
DEBUG=false
ENVIRONMENT=staging

# Public CORS — must include the Vercel preview URL
CORS_ORIGINS=https://staging.stridealytics.com,https://staging-web.vercel.app

# --- Supabase (STAGING project) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Notifications ---
SENDGRID_API_KEY=
SLACK_WEBHOOK=https://hooks.slack.com/services/STAGING/...

# --- Frontend ---
VITE_API_URL=https://api-staging.stridealytics.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=staging
