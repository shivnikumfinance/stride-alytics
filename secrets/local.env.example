# ============================================================================
# secrets/local.env — YOUR LOCAL DEV SECRETS (git-ignored)
# ============================================================================
#
# Copy this file to `secrets/local.env` and fill in real values.
# The `load-secrets` script reads this file and propagates keys into
# backend/.env, frontend/.env, and scheduler/.env.
#
# Run:
#   cp secrets/local.env.example secrets/local.env
#   scripts/load-secrets.ps1 -Env local
# ============================================================================

# --- App ---
APP_NAME=StrideAlytics
DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (Supabase / Postgres) ---
# Find in: Supabase ? Project ? Settings ? Database ? Connection string
# Local alternative: use docker compose -f infra/docker/docker-compose.yml up
# and set DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stridealytics
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.gteipadnxxwztfhomfji.supabase.co:5432/postgres
DATABASE_POOL_SIZE=5

# --- Supabase Auth ---
# Project Settings ? API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# --- Email (weekly picks) ---
SENDGRID_API_KEY=

# --- Slack alerts (scheduler failures) ---
SLACK_WEBHOOK=https://hooks.slack.com/services/T00/B00/YOUR_WEBHOOK_TOKEN

# --- Mobile (EAS, optional) ---
EXPO_TOKEN=YOUR_EXPO_TOKEN

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
VITE_APP_NAME=StrideAlytics
VITE_APP_ENV=development

# --- Scheduler ---
# These map to the secrets above automatically; the loader propagates them.