# ============================================================================
# StrideAlytics root .gitignore
# Per-package ignore rules live alongside the package
# (e.g. backend/.dockerignore, frontend/.gitignore).
# ============================================================================

# ---- OS ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- Editors / IDEs ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.cursor/

# ---- Secrets (block everything except tracked templates) ----
.env
.env.local
.env.*.local
.env.production
.env.development

# Allow committing the .env.example templates at any level
!**/.env.example

# Block every real file under secrets/ except the tracked templates + README
secrets/*.env
secrets/*.env.local
secrets/*.key
secrets/*.pem
secrets/google-credentials*.json
secrets/firebase-*.json
# Explicitly keep these tracked (overrides the rules above)
!secrets/README.md
!secrets/local.env.example
!secrets/staging.env.example
!secrets/production.env.example
!secrets/github-secrets.txt

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/

# ---- Node / Frontend ----
node_modules/
.npm/
.yarn/
.pnp.*
.parcel-cache/
.vite/

# ---- Expo / Mobile ----
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/.eas-build/
mobile/.npmrc

# ---- Build artefacts ----
*.log
logs/

# ---- Test outputs ----
coverage/
.nyc_output/
test-results/
playwright-report/

# ---- OS noise ----
*.tmp
*.bak
*.orig

# ---- Editor auto-saves ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json`r`n# Secret scrubbing tools`r`nfilter-replacements.txt`r`nscrub-secrets.py`r`n
.vercel
.env*
